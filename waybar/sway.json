[{
    "position": "bottom",
    "height": 45,
    "spacing": 0,
    "output": "eDP-1",
    "reload_style_on_change": true,
    "mode": "dock",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-right": ["mpd", "image#album-art", "pulseaudio", "cpu", "memory", "battery", "disk", "backlight", "custom/clock"],
    "sway/workspaces": {
         "disable-scroll": false,
         "disable-scroll-wraparound": true,
         "enable-bar-scroll": true,
         "all-outputs": false,
         "format": "{icon}",
         "format-icons": {
             "1": "ΎΝχ",
             "2": "≤░Ψθ",
             "3": "ΎΑΒ",
             "4": "ΎΕκ",
             "5": "ΎΘ╝",
             "6": "ΎΗ╢",
             "7": "ΎΡψ",
             "8": "≤░ρε",
             "9": "ΌγΠ",
             "urgent": "ΎΒς",
             "default": "ΎΕΣ"
         }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

"mpd": {
    "server": "127.0.0.2",
    "port": 6602,
    "password": "passgasgrassorazz",
    "format": "{artist} - <span style=\"italic\">{title}</span>{consumeIcon}{singleIcon}{repeatIcon}{randomIcon}{stateIcon}",
    "format-disconnected": "ΎΑΒ ",
    "format-stopped": "{consumeIcon}{singleIcon}{repeatIcon}{randomIcon}",
    "title-len": 40,
    "unknown-tag": "N/A",
    "interval": 1,
    "on-click": "mpc --host='passgasgrassorazz@127.0.0.2' --port=6602 toggle > /dev/null",
    "on-click-right": "mpc --host='passgasgrassorazz@127.0.0.2' --port=6602 next > /dev/null",
    "on-click-middle": "mpc --host='passgasgrassorazz@127.0.0.2' --port=6602 prev > /dev/null",
    "consume-icons": {
        "on": " ≤░χψ "
    },
    "random-icons": {
        "off": " ",
        "on": " ΎΒ┤ "
    },
    "repeat-icons": {
        "on": " ΎΑη "
    },
    "single-icons": {
        "on": " ΎΑη 1"
    },
    "state-icons": {
        "playing": "ΎΒΝ ",
        "paused": "ΎΒΜ "
    },
    "tooltip-format": "{artist} - {album} ({date})",
},

"image#album-art": {
    "path": "/tmp/rmpc/notification",
    "size": 38,
    "interval": 1,
    "on-click": "swayimg /tmp/rmpc/notification",
    "on-click-right": "footclient -e rmpc -c /home/babkock/.config/rmpc/config.ron"
},

"custom/clock": {
    "exec": "date +'%I:%M:%S ΎΒ│ %a, %b %d'",
    "interval": 1,
    "format": "ΎΑΩ {}",
    "align": 1,
    "tooltip": false
},

"cpu": {
    "format": "ΌΙ╕ {usage}%",
    "format-alt": "ΌΙ╕ {avg_frequency} GHz {max_frequency} GHz",
    "on-click-right": "footclient -e htop"
},

"memory": {
    "format": "ΎΜδ {}%",
    "format-alt": "Ό┐Ζ {used:0.1f} GB ΌψΜ {swapUsed:0.1f} GB",
    "tooltip-format": "Ό┐Ζ {used:0.2f} GB ΌψΜ {swapUsed:0.2f} GB",
    "on-click-right": "footclient -e lf"
},

"disk": {
    "path": "/mnt/mega/",
    "interval": 1,
    "format": "≤░ΜΛ <span style=\"italic\">{free}</span>",
    "format-alt": "≤░ΜΛ {used}",
    "tooltip": true,
    "tooltip-format": "{path} ({percentage_used}% of {total})",
    "on-click-right": "pkill -9 pcmanfm; pcmanfm /mnt/mega"
},

"battery": {
    "states": {
        "good": 99,
        "warning": 50,
        "critical": 20
    },
    "full-at": 94,
    "format": "{icon}  <span style=\"italic\">{capacity}%</span>",
    "format-charging": "ΎΩπ <span style=\"italic\">{capacity}%</span>",
    "format-plugged": "ΎΘο {capacity}%",
    "format-alt": "{icon}  ΎΑΩ {time}",
    "format-time": "{H}:{m}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ", "ΌΙ║"],
    "tooltip": true,
    "tooltip-format": "ΎΑΩ {time} ≤▒ΡΜ {power} watts"
},

"backlight": {
    "device": "intel_backlight",
    "tooltip": false,
    "format": "{icon} {percent}%",
    "format-icons": ["ΌΟΞ", "≤░ςη", "≤░ςθ", "≤░ςι", "≤░ςκ", "≤░ςλ", "≤░ςμ", "≤░ςν", "≤░ςξ"],
    "on-click-right": "pkill -x gammastep; gammastep -O 4500K",
    "on-click-middle": "pkill -x gammastep",
    "on-click": "light -S 20 && light -G && echo 20 > .wob.sock",
    "on-scroll-up": "light -A 1 && light -G | cut -d'.' -f1 > /home/babkock/.wob.sock",
    "on-scroll-down": "light -U 1 && light -G | cut -d'.' -f1 > /home/babkock/.wob.sock",
},

"pulseaudio": {
    "format": "{icon} <span style=\"italic\">{volume}%</span> {format_source}",
    "format-bluetooth": "{icon} ΎΛΦ <span style=\"italic\">{volume}%</span>",
    "format-bluetooth-muted": "ΎΑο ΎΛΦ {volume}%",
    "format-muted": "ΎΑο {volume}%",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "tooltip": true,
    "tooltip-format": "{desc}",
    "format-icons": {
        "headphone": "ΎΑξ",
        "hands-free": "ΎΨΡ",
        "headset": "ΎΨΡ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click-right": "env PULSE_LATENCY_MSEC=60 pavucontrol",
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle && pactl get-sink-volume @DEFAULT_SINK@ | head -n 1 | awk '{print substr($5, 1, length($5)-1)}' > /home/babkock/.wob.sock",
    "on-scroll-up": "env PULSE_LATENCY_MSEC=60 wpctl set-volume @DEFAULT_SINK@ 2%+ && pactl get-sink-volume @DEFAULT_SINK@ | head -n 1 | awk '{print substr($5, 1, length($5)-1)}' > /home/babkock/.wob.sock",
    "on-scroll-down": "env PULSE_LATENCY_MSEC=60 wpctl set-volume @DEFAULT_SINK@ 2%- && pactl get-sink-volume @DEFAULT_SINK@ | head -n 1 | awk '{print substr($5, 1, length($5)-1)}' > /home/babkock/.wob.sock",
}

